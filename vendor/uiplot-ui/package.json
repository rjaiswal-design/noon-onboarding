{
  "name": "@uiplot/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./tokens.css": "./tokens.css",
